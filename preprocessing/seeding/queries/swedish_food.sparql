PREFIX wd: <http://www.wikidata.org/entity/>
PREFIX wdt: <http://www.wikidata.org/prop/direct/>
PREFIX wikibase: <http://wikiba.se/ontology#>
PREFIX bd: <http://www.bigdata.com/rdf#>
PREFIX schema: <http://schema.org/>

# ── Timeout fix ───────────────────────────────────────────────────────────────
# REMOVED: wdt:P31/wdt:P279* (transitive subclass traversal — main timeout cause)
# REPLACED WITH: wdt:P31 + VALUES listing concrete food/drink QIDs.
#
# Two complementary patterns run in UNION so each sub-query is small:
#   (A) General food/drink types on the Swedish Wikipedia — captures global
#       foods that Swedes know (pizza, sushi, hamburger, …)
#   (B) Dishes/products explicitly tagged with Swedish cuisine (P361 Q858139)
#       — catches klassiker like kanelbulle, semla, surströmming, köttbullar
#       even if they have fewer sitelinks.
# ─────────────────────────────────────────────────────────────────────────────

SELECT DISTINCT ?food ?foodLabel ?sitelinks WHERE {
  {
    # (A) Food/drink with Swedish Wikipedia article
    ?svArticle schema:isPartOf <https://sv.wikipedia.org/> ;
               schema:about ?food .

    VALUES ?foodType {
      wd:Q2095       # food
      wd:Q40050      # alcoholic drink
      wd:Q10884      # tea
      wd:Q8492       # coffee
      wd:Q8341       # beer
      wd:Q178359     # beverage
      wd:Q746549     # dish
      wd:Q213441     # candy / confectionery
      wd:Q132710     # pastry / baked good
      wd:Q28113351   # fast food dish
      wd:Q1778821    # Swedish cuisine dish  
      wd:Q19861951   # food product
    }
    ?food wdt:P31 ?foodType .   # direct only — no P279*

    ?food wikibase:sitelinks ?sitelinks .
    FILTER(?sitelinks > 4)
  }
  UNION
  {
    # (B) Explicitly part of Swedish cuisine (lower sitelinks OK — still culturally important)
    ?food wdt:P361 wd:Q858139 .  # part of: Swedish cuisine

    VALUES ?foodType {
      wd:Q2095 wd:Q746549 wd:Q132710 wd:Q213441 wd:Q19861951
    }
    ?food wdt:P31 ?foodType .

    ?food wikibase:sitelinks ?sitelinks .
    FILTER(?sitelinks > 1)
  }

  SERVICE wikibase:label { bd:serviceParam wikibase:language "sv,en" . }
}
LIMIT 400
