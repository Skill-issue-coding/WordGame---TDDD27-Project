PREFIX wd: <http://www.wikidata.org/entity/>
PREFIX wdt: <http://www.wikidata.org/prop/direct/>
PREFIX wikibase: <http://wikiba.se/ontology#>
PREFIX bd: <http://www.bigdata.com/rdf#>
PREFIX schema: <http://schema.org/>

# ── Already safe (no P279* traversal) ────────────────────────────────────────
# All P31 lookups use VALUES → direct instances only → fast.
#
# Additions vs original:
#   - tech/software companies (Q2500638) — Spotify, Klarna, King, iZettle…
#   - media company (Q10870555)         — SVT, TV4, Aftonbladet …
#   - airline (Q46970)                  — SAS, Norwegian
#   - Added sitelinks > 2 filter to drop purely stub articles.
# ─────────────────────────────────────────────────────────────────────────────

SELECT DISTINCT ?company ?companyLabel ?sitelinks WHERE {

  # Anchor: Swedish Wikipedia page
  ?svArticle schema:isPartOf <https://sv.wikipedia.org/> ;
             schema:about ?company .

  VALUES ?companyType {
    wd:Q270791    # supermarket chain
    wd:Q180792    # department store
    wd:Q1780004   # retail chain
    wd:Q212108    # restaurant chain
    wd:Q22687     # bank
    wd:Q1750662   # transport company
    wd:Q245081    # clothing brand
    wd:Q6881511   # enterprise
    wd:Q783794    # company
    wd:Q891723    # public company
    wd:Q2500638   # software company / tech company
    wd:Q10870555  # media company
    wd:Q46970     # airline
    wd:Q740752    # insurance company
    wd:Q17149090  # brand
  }
  ?company wdt:P31 ?companyType .   # direct only — no P279*
  ?company wdt:P17 wd:Q34 .         # country: Sweden

  ?company wikibase:sitelinks ?sitelinks .
  FILTER(?sitelinks > 2)

  SERVICE wikibase:label { bd:serviceParam wikibase:language "sv,en" . }
}
LIMIT 400
